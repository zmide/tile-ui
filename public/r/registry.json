      ]
    },
    {
      "name": "card",
      "type": "components:ui",
      "description": "UI 组件",
      "dependencies": [],
      "devDependencies": [
        "sass"
      ],
      "files": [
        "/registry/new-york/ui/card/card.tsx",
        "/registry/new-york/ui/card/card.module.scss"
      ]
    },
    {
      "name": "hooks",
      "type": "hooks",
      "description": "自定义 React Hooks",
      "dependencies": [],
      "devDependencies": [
        "sass"
      ],
      "files": [
        "/hooks/use-local-storage.ts",
