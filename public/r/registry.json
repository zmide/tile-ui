        "@radix-ui/react-slot"
      ],
      "devDependencies": [
        "sass"
      ],
      "files": [
        "/registry/new-york/ui/button/button.tsx",
        "/registry/new-york/ui/button/button.module.scss"
      ]
    },
    {
      "name": "input",
      "type": "components:ui",
      "description": "UI 组件",
      "dependencies": [],
      "devDependencies": [
        "sass"
      ],
      "files": [
        "/registry/new-york/ui/input/input.tsx",
        "/registry/new-york/ui/input/input.module.scss"
      ]
    },
    {
      "name": "textarea",
      "type": "components:ui",
      "description": "UI 组件",
      "dependencies": [],
      "devDependencies": [
        "sass"
      ],
      "files": [
        "/registry/new-york/ui/textarea/textarea.tsx",
        "/registry/new-york/ui/textarea/textarea.module.scss"
      ]
    },
    {
      "name": "label",
      "type": "components:ui",
      "description": "UI 组件",
      "dependencies": [
        "@radix-ui/react-label"
      ],
