{
  "name": "tile-ui",
  "description": "基于 SCSS + CSS Module + Hooks API 的轻量级 React 组件库",
  "homepage": "/",
  "style": "new-york",
  "rsc": true,
  "tsx": true,
  "tailwind": false,
  "cssVariables": false,
  "registryDependencies": [],
  "registry": [
    {
      "name": "button",
      "type": "components:ui",
      "description": "UI 组件",
