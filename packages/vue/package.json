{
	"name": "@tile-ui/vue",
	"version": "1.0.1",
	"private": false,
	"files": [
		"README.md",
		"dist"
	],
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./composables": {
			"import": {
				"types": "./dist/composables/index.d.ts",
				"default": "./dist/composables/index.js"
			},
			"require": {
				"types": "./dist/composables/index.d.cts",
				"default": "./dist/composables/index.cjs"
			}
		}
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"lint": "oxlint -c .oxlintrc.json .",
		"type:check": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@tile-ui/core": "workspace:*"
	},
	"devDependencies": {
		"@tile-ui/buildx": "workspace:*",
		"@vue/tsconfig": "^0.7.0",
		"sass": "^1.86.3",
		"tsup": "^8.4.0",
		"typescript": "^5.9.2",
		"vue": "^3.5.0"
	},
	"peerDependencies": {
		"@tile-ui/styles": "workspace:*",
		"vue": ">=3.3.0"
	}
}
