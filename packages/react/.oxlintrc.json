{
  "$schema": "../../node_modules/oxlint/configuration_schema.json",
  "plugins": ["oxc", "typescript", "unicorn", "react"],
  "categories": {
    "correctness": "error"
  },
  "ignorePatterns": [
    "dist/**",
    "node_modules/**"
  ],
  "overrides": [
    {
      "files": [
        "src/**/*.{ts,tsx}",
        "tsup.config.ts"
      ]
    }
  ]
}
