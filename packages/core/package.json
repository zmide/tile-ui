{
	"name": "@tile-ui/core",
	"version": "1.0.1",
	"private": false,
	"files": [
		"README.md",
		"dist"
	],
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./utils": {
			"import": {
				"types": "./dist/utils/index.d.ts",
				"default": "./dist/utils/index.js"
			},
			"require": {
				"types": "./dist/utils/index.d.cts",
				"default": "./dist/utils/index.cjs"
			}
		},
		"./tokens": {
			"import": {
				"types": "./dist/tokens/index.d.ts",
				"default": "./dist/tokens/index.js"
			},
			"require": {
				"types": "./dist/tokens/index.d.cts",
				"default": "./dist/tokens/index.cjs"
			}
		}
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/zmide/tile-ui.git",
		"directory": "packages/core"
	},
	"homepage": "https://github.com/zmide/tile-ui/tree/main/packages/core",
	"bugs": {
		"url": "https://github.com/zmide/tile-ui/issues"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"lint": "oxlint -c .oxlintrc.json .",
		"type:check": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"devDependencies": {
		"tsup": "^8.4.0",
		"typescript": "^5.9.2"
	}
}
