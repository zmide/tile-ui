{
	"name": "@tile-ui/react-docs",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"registry:build": "tsx ./scripts/build-registry.mjs",
		"registry:watch": "tsx ./scripts/watch-registry.mjs",
		"dev:app": "next dev --turbopack -p 3001",
		"dev": "pnpm exec concurrently -k -n registry,app -c cyan,magenta \"pnpm registry:watch\" \"pnpm dev:app\"",
		"build": "next build",
		"start": "next start",
		"lint": "oxlint -c .oxlintrc.json .",
		"type:check": "tsc --noEmit",
		"fmt:check": "oxfmt --check .",
		"check": "pnpm lint && pnpm type:check && pnpm fmt:check",
		"postinstall": "fumadocs-mdx"
	},
	"dependencies": {
		"@radix-ui/react-label": "^2.1.7",
		"@radix-ui/react-slot": "^1.2.3",
		"@tile-ui/buildx": "workspace:*",
		"@tile-ui/core": "workspace:*",
		"@tile-ui/react": "workspace:*",
		"@tile-ui/styles": "workspace:*",
		"fumadocs-core": "16.0.5",
		"fumadocs-ui": "16.0.5",
		"next": "15.5.9",
		"react": "19.1.0",
		"react-dom": "19.1.0",
		"rehype-pretty-code": "0.14.1",
		"shiki": "^1.10.1"
	},
	"devDependencies": {
		"@types/mdx": "2.0.13",
		"@types/node": "^20.19.9",
		"@types/react": "19.1.2",
		"@types/react-dom": "19.1.2",
		"concurrently": "^9.2.1",
		"fumadocs-mdx": "13.0.2",
		"sass": "^1.86.3",
		"tsx": "^4.20.3",
		"typescript": "^5.9.2"
	},
	"overrides": {
		"@types/react": "19.1.2",
		"@types/react-dom": "19.1.2"
	}
}
