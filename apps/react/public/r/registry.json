        {
          "path": "packages/react/src/hooks/use-local-storage.ts",
          "type": "registry:hook",
          "target": "hooks/use-local-storage.ts"
        }
      ]
    },
    {
      "name": "button",
      "type": "registry:ui",
      "title": "Button",
      "description": "Multi-variant React button component for Tile UI.",
      "dependencies": [
        "@radix-ui/react-slot"
      ],
      "devDependencies": [
        "sass"
      ],
      "registryDependencies": [
        "@tile-ui/core",
        "@tile-ui/utils"
      ],
      "files": [
        {
          "path": "packages/react/src/components/button/button.tsx",
          "type": "registry:ui"
        },
        {
          "path": "packages/styles/scss/components/button.module.scss",
          "type": "registry:file",
          "target": "components/ui/button/button.module.scss"
        }
      ]
    },
    {
