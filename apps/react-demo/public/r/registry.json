{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "tile-ui",
  "homepage": "https://tile-ui.dev",
  "items": [
    {
      "name": "button",
      "type": "registry:ui",
      "title": "Button",
      "description": "多变体按钮组件，支持 loading、asChild、多种变体和尺寸",
      "dependencies": ["@radix-ui/react-slot"],
      "devDependencies": ["sass"],
      "registryDependencies": [],
      "files": [
        {
          "path": "registry/tile-ui/button/button.tsx",
          "type": "registry:ui"
        },
        {
          "path": "registry/tile-ui/button/button.module.scss",
          "type": "registry:file",
          "target": "components/ui/button/button.module.scss"
        }
      ]
    },
    {
      "name": "input",
      "type": "registry:ui",
      "title": "Input",
      "description": "输入框组件，支持 label、error 校验、helperText 辅助文本",
      "devDependencies": ["sass"],
      "registryDependencies": [],
      "files": [
        {
          "path": "registry/tile-ui/input/input.tsx",
          "type": "registry:ui"
        },
        {
          "path": "registry/tile-ui/input/input.module.scss",
          "type": "registry:file",
          "target": "components/ui/input/input.module.scss"
        }
      ]
    },
    {
      "name": "textarea",
      "type": "registry:ui",
      "title": "Textarea",
      "description": "多行文本域组件，支持 label、error 校验、helperText 辅助文本",
      "devDependencies": ["sass"],
      "registryDependencies": [],
      "files": [
        {
          "path": "registry/tile-ui/textarea/textarea.tsx",
          "type": "registry:ui"
        },
        {
          "path": "registry/tile-ui/textarea/textarea.module.scss",
          "type": "registry:file",
          "target": "components/ui/textarea/textarea.module.scss"
        }
      ]
    },
    {
      "name": "label",
      "type": "registry:ui",
      "title": "Label",
      "description": "表单标签组件，基于 Radix Label，支持必填标记",
      "dependencies": ["@radix-ui/react-label"],
      "devDependencies": ["sass"],
      "registryDependencies": [],
      "files": [
        {
          "path": "registry/tile-ui/label/label.tsx",
          "type": "registry:ui"
        },
        {
          "path": "registry/tile-ui/label/label.module.scss",
          "type": "registry:file",
          "target": "components/ui/label/label.module.scss"
        }
      ]
    },
    {
      "name": "card",
      "type": "registry:ui",
      "title": "Card",
      "description": "卡片容器组件，包含 Header/Title/Description/Content/Footer 子组件",
      "devDependencies": ["sass"],
      "registryDependencies": [],
      "files": [
        {
          "path": "registry/tile-ui/card/card.tsx",
          "type": "registry:ui"
        },
        {
          "path": "registry/tile-ui/card/card.module.scss",
          "type": "registry:file",
          "target": "components/ui/card/card.module.scss"
        }
      ]
    },
    {
      "name": "utils",
      "type": "registry:lib",
      "title": "Utils",
      "description": "工具函数集合：cn 类名合并、generateId、deepMerge、formatBytes 等",
      "files": [
        {
          "path": "registry/tile-ui/lib/utils.ts",
          "type": "registry:lib"
        }
      ]
    },
    {
      "name": "use-copy-to-clipboard",
      "type": "registry:hook",
      "title": "useCopyToClipboard",
      "description": "复制文本到剪贴板 Hook，支持超时自动重置",
      "files": [
        {
          "path": "registry/tile-ui/hooks/use-copy-to-clipboard.ts",
          "type": "registry:hook"
        }
      ]
    },
    {
      "name": "use-media-query",
      "type": "registry:hook",
      "title": "useMediaQuery",
      "description": "媒体查询响应式 Hook，含 useWindowSize / useIsMobile / useOnlineStatus / useScrollPosition",
      "files": [
        {
          "path": "registry/tile-ui/hooks/use-media-query.ts",
          "type": "registry:hook"
        }
      ]
    },
    {
      "name": "use-local-storage",
      "type": "registry:hook",
      "title": "useLocalStorage",
      "description": "本地存储 / 会话存储 Hook，类型安全且支持 SSR",
      "files": [
        {
          "path": "registry/tile-ui/hooks/use-local-storage.ts",
          "type": "registry:hook"
        }
      ]
    },
    {
      "name": "styles",
      "type": "registry:file",
      "title": "Global Styles",
      "description": "SCSS 全局样式、设计 Token 变量和混入工具",
      "devDependencies": ["sass"],
      "files": [
        {
          "path": "registry/tile-ui/styles/globals.scss",
          "type": "registry:file",
          "target": "styles/globals.scss"
        },
        {
          "path": "registry/tile-ui/styles/variables/_colors.scss",
          "type": "registry:file",
          "target": "styles/variables/_colors.scss"
        },
        {
          "path": "registry/tile-ui/styles/mixins/_utils.scss",
          "type": "registry:file",
          "target": "styles/mixins/_utils.scss"
        }
      ]
    }
  ]
}
