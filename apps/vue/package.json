{
	"name": "@tile-ui/vue-docs",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"docs:build": "node ./scripts/build-docs.mjs",
		"registry:build": "tsx ./scripts/build-registry.mjs",
		"registry:watch": "tsx ./scripts/watch-registry.mjs",
		"predev": "npm run docs:build",
		"dev:app": "nuxi dev -p 3002",
		"dev": "pnpm exec concurrently -k -n registry,app -c cyan,magenta \"pnpm registry:watch\" \"pnpm dev:app\"",
		"prebuild": "npm run docs:build",
		"build": "nuxi build",
		"pregenerate": "npm run docs:build",
		"generate": "nuxi generate",
		"preview": "nuxi preview",
		"pretype:check": "npm run docs:build",
		"lint": "oxlint -c .oxlintrc.json .",
		"type:check": "vue-tsc --noEmit",
		"fmt:check": "oxfmt --check .",
		"check": "pnpm lint && pnpm type:check && pnpm fmt:check"
	},
	"dependencies": {
		"@tile-ui/buildx": "workspace:*",
		"@tile-ui/core": "workspace:*",
		"@tile-ui/styles": "workspace:*",
		"@tile-ui/vue": "workspace:*",
		"gray-matter": "^4.0.3",
		"markdown-it": "^14.1.1",
		"markdown-it-anchor": "^9.2.0",
		"nuxt": "^3.16.0",
		"vue": "^3.5.0"
	},
	"devDependencies": {
		"@types/node": "^25.5.2",
		"concurrently": "^9.2.1",
		"sass": "^1.86.3",
		"tsx": "^4.20.3",
		"typescript": "^5.9.2",
		"vue-tsc": "^3.1.2"
	}
}
