{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "tile-ui-vue",
  "homepage": "https://vue.tile-ui.dev",
  "items": [
    {
      "name": "core",
      "type": "registry:lib",
      "title": "Core",
      "description": "Framework-agnostic helpers required by Vue registry components.",
      "files": [
        {
          "path": "registry/vue/tile-ui/lib/core.ts",
          "type": "registry:lib",
          "target": "components/ui/lib/core.ts"
        }
      ]
    },
    {
      "name": "button",
      "type": "registry:ui",
      "title": "Button",
      "description": "Multi-variant Vue button component for Tile UI.",
      "dependencies": ["vue"],
      "devDependencies": ["sass"],
      "registryDependencies": ["core"],
      "files": [
        {
          "path": "registry/vue/tile-ui/button/button.tsx",
          "type": "registry:ui"
        },
        {
          "path": "registry/vue/tile-ui/button/button.module.scss",
          "type": "registry:file",
          "target": "components/ui/button/button.module.scss"
        }
      ]
    },
    {
      "name": "input",
      "type": "registry:ui",
      "title": "Input",
      "description": "Vue input component with label, error and helper text.",
      "dependencies": ["vue"],
      "devDependencies": ["sass"],
      "registryDependencies": ["core"],
      "files": [
        {
          "path": "registry/vue/tile-ui/input/input.tsx",
          "type": "registry:ui"
        },
        {
          "path": "registry/vue/tile-ui/input/input.module.scss",
          "type": "registry:file",
          "target": "components/ui/input/input.module.scss"
        }
      ]
    },
    {
      "name": "textarea",
      "type": "registry:ui",
      "title": "Textarea",
      "description": "Vue textarea component with label, error and helper text.",
      "dependencies": ["vue"],
      "devDependencies": ["sass"],
      "registryDependencies": ["core"],
      "files": [
        {
          "path": "registry/vue/tile-ui/textarea/textarea.tsx",
          "type": "registry:ui"
        },
        {
          "path": "registry/vue/tile-ui/textarea/textarea.module.scss",
          "type": "registry:file",
          "target": "components/ui/textarea/textarea.module.scss"
        }
      ]
    },
    {
      "name": "label",
      "type": "registry:ui",
      "title": "Label",
      "description": "Vue label component with required state support.",
      "dependencies": ["vue"],
      "devDependencies": ["sass"],
      "registryDependencies": ["core"],
      "files": [
        {
          "path": "registry/vue/tile-ui/label/label.tsx",
          "type": "registry:ui"
        },
        {
          "path": "registry/vue/tile-ui/label/label.module.scss",
          "type": "registry:file",
          "target": "components/ui/label/label.module.scss"
        }
      ]
    },
    {
      "name": "card",
      "type": "registry:ui",
      "title": "Card",
      "description": "Composable Vue card container for Tile UI.",
      "dependencies": ["vue"],
      "devDependencies": ["sass"],
      "registryDependencies": ["core"],
      "files": [
        {
          "path": "registry/vue/tile-ui/card/card.tsx",
          "type": "registry:ui"
        },
        {
          "path": "registry/vue/tile-ui/card/card.module.scss",
          "type": "registry:file",
          "target": "components/ui/card/card.module.scss"
        }
      ]
    },
    {
      "name": "utils",
      "type": "registry:lib",
      "title": "Utils",
      "description": "Shared utility helpers for the Vue registry.",
      "files": [
        {
          "path": "registry/vue/tile-ui/lib/utils.ts",
          "type": "registry:lib",
          "target": "components/ui/lib/utils.ts"
        }
      ]
    },
    {
      "name": "use-copy-to-clipboard",
      "type": "registry:hook",
      "title": "useCopyToClipboard",
      "description": "Vue composables for clipboard and DOM event helpers.",
      "dependencies": ["vue"],
      "files": [
        {
          "path": "registry/vue/tile-ui/composables/use-copy-to-clipboard.ts",
          "type": "registry:hook",
          "target": "composables/use-copy-to-clipboard.ts"
        }
      ]
    },
    {
      "name": "use-media-query",
      "type": "registry:hook",
      "title": "useMediaQuery",
      "description": "Vue composables for viewport and media query state.",
      "dependencies": ["vue"],
      "files": [
        {
          "path": "registry/vue/tile-ui/composables/use-media-query.ts",
          "type": "registry:hook",
          "target": "composables/use-media-query.ts"
        }
      ]
    },
    {
      "name": "use-local-storage",
      "type": "registry:hook",
      "title": "useLocalStorage",
      "description": "Vue composables for local and session storage.",
      "dependencies": ["vue"],
      "files": [
        {
          "path": "registry/vue/tile-ui/composables/use-local-storage.ts",
          "type": "registry:hook",
          "target": "composables/use-local-storage.ts"
        }
      ]
    },
    {
      "name": "styles",
      "type": "registry:file",
      "title": "Global Styles",
      "description": "SCSS globals and design tokens for the Vue registry.",
      "devDependencies": ["sass"],
      "files": [
        {
          "path": "registry/vue/tile-ui/styles/globals.scss",
          "type": "registry:file",
          "target": "styles/globals.scss"
        },
        {
          "path": "registry/vue/tile-ui/styles/variables/_colors.scss",
          "type": "registry:file",
          "target": "styles/variables/_colors.scss"
        },
        {
          "path": "registry/vue/tile-ui/styles/mixins/_utils.scss",
          "type": "registry:file",
          "target": "styles/mixins/_utils.scss"
        }
      ]
    }
  ]
}
