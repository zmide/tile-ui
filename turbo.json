{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", "css/**", ".next/**", ".nuxt/**", ".output/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"lint": {
			"outputs": []
		},
		"type-check": {
			"dependsOn": ["^build"]
		},
		"clean": {
			"cache": false
		}
	}
}
