{
  "name": "tile-ui",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "check": "pnpm lint && pnpm type-check",
    "type-check": "turbo type-check",
    "clean": "turbo clean",
    "registry:build:react": "pnpm --filter @tile-ui/react-docs registry:build",
    "registry:build:vue": "pnpm --filter @tile-ui/vue-docs registry:build",
    "registry:build": "pnpm registry:build:react && pnpm registry:build:vue",
    "docs:check": "node scripts/check-docs.mjs",
    "test:buildx": "pnpm --filter @tile-ui/buildx test"
  },
  "devDependencies": {
    "oxlint": "^1.18.0",
    "turbo": "^2.4.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@9.15.0"
}
